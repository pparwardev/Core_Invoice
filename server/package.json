    "exceljs": "4.4.0",
    "express": "4.21.1",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "9.0.2",
    "knex": "3.1.0",
    "multer": "1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdf-parse": "^1.1.1",
    "pdfkit": "0.15.0",
    "pg": "^8.21.0",
