# Google Gemini AI API Key (required for log sheet scanning)
# Get your free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (optional, defaults to 3001)
PORT=3001

# JWT Secret (optional, defaults to a local key)
JWT_SECRET=your-secret-key

# Email Configuration (for verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Core-Invoice <your-email@gmail.com>

# App URL (for verification links)
APP_URL=http://localhost:3001
